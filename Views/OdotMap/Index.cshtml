@{
    ViewData["Title"] = "ODOT Traffic Incidents";
}

<!-- ArcGIS JS API from Esri CDN -->
<!-- (rendering this in the <head>) -->
@section HeadScripts {
    <link rel="stylesheet" href="https://js.arcgis.com/4.30/esri/themes/light/main.css" />
}

<h1>ODOT Traffic Incident Map</h1>

<div id="filter-sidebar" class="p-3">
    <h6 class="fw-bold">Filter Incidents</h6>
</div>
<div id="viewDiv"></div>
<div id="cache-info"></div>

@section Scripts {
    <script type="module" src="~/js/odotMap.js"></script>
}